{
  "manifest_version": 3,
  "name": "Briefly",
  "version": "1.0.0",
  "description": "Voice-powered AI assistant that converts speech to structured text, prompts, and actions — directly in your browser.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Briefly",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "offscreen",
    "scripting",
    "tabs",
    "commands",
    "notifications"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open / close Briefly side panel"
    },
    "push-to-talk": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space",
        "mac": "Command+Shift+Space"
      },
      "description": "Push-to-talk record"
    },
    "copy-last-output": {
      "suggested_key": {
        "default": "Ctrl+Shift+C",
        "mac": "Command+Shift+C"
      },
      "description": "Copy last output to clipboard"
    },
    "toggle-history": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Command+Shift+H"
      },
      "description": "Toggle history panel"
    },
    "retry-last": {
      "description": "Retry last Briefly request"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["offscreen/offscreen.html", "onboarding/onboarding.html", "onboarding/onboarding.js", "lib/*.js", "lib/vendor/*.css", "styles/*.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net;"
  },
  "default_locale": "en"
}
