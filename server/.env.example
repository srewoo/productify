# Productify Backend Environment Variables
# Copy this file to .env and fill in values

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated allowed origins (leave empty to allow all in dev)
ALLOWED_ORIGINS=chrome-extension://
ELEVEN_STT_MODEL_ID=scribe_v2   # or scribe_v1 / scribe_v1_experimental


# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_GENERATION_MODEL=gpt-4o-mini

# NOTE: API keys are NOT stored here.
# All API keys (OpenAI, Google STT, integrations) are passed by the extension
# in request headers. This server acts as a proxy/orchestrator only.
# This is the BYOK (Bring Your Own Key) model.

# Optional: a shared server-side OpenAI key for demo/testing ONLY
# DEMO_OPENAI_KEY=sk-...

# Optional: Google STT credentials for server-side fallback
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
